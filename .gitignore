.env
HELP.md
target/
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

### STS ###
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache


.vscode/

# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
.bundle

# Ignore all environment files.
.env*

# Ignore all logfiles and tempfiles.
log/*
tmp/*
!log/.keep
!tmp/.keep

# Ignore pidfiles, but keep the directory.
tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
storage/*
!storage/.keep
tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

public/assets

# Ignore key files for decrypting credentials and more.
config/*.key

############################
# Ruby / Rails
############################
*.gem
*.rbc
.bundle
backendRubyOnRails/*/vendor/bundle
backendRubyOnRails/*/vendor/cache
backendRubyOnRails/*/vendor/ruby
.ruby-version
.ruby-gemset

############################
# Rails runtime
############################
log/*
tmp/*
storage/*
!log/.keep
!tmp/.keep
!storage/.keep

############################
# Database
############################
backendRubyOnRails/*/db/*.sqlite3
backendRubyOnRails/*/db/*.sqlite3-journal
backendRubyOnRails/*/db/*.sqlite3-*
############################
# Credentials / Secrets
############################
backendRubyOnRails/*/config/master.key
backendRubyOnRails/*/config/credentials/*.key
backendRubyOnRails/*/config/credentials/*.yml.enc

############################
# Environment variables
############################
.env
.env.*
.envrc

############################
# Node / JS (Rails 7+)
############################
node_modules/
yarn-error.log
npm-debug.log*
.pnpm-debug.log*

############################
# Assets
############################
public/assets
public/packs
public/packs-test
public/vite

############################
# OS / Editor
############################
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

############################
# Test / Coverage
############################
coverage/
spec/examples.txt

